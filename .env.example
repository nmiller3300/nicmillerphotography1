# ─── Admin Auth ───────────────────────────────────────────────────────────────
# 6-digit PIN for the admin login overlay. Set in Vercel env vars — never commit.
ADMIN_PIN=004089

# Signing secret for iron-session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters.
SESSION_SECRET=replace_with_32_plus_char_random_string

# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Project: nic-miller-photography
# Project ID: zaokceyturwcfowlvyna
# Region: us-east-1
#
# Get your database password from:
#   Supabase Dashboard → Project Settings → Database → Database password
#
# TRANSACTION POOLER — used at runtime (safe for serverless/Vercel)
DATABASE_URL="postgresql://postgres.zaokceyturwcfowlvyna:[YOUR-DB-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT CONNECTION — used by Prisma Migrate only (add to .env.local but NOT Vercel runtime vars)
DIRECT_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.zaokceyturwcfowlvyna.supabase.co:5432/postgres"

# ─── Blob Storage (Vercel) ────────────────────────────────────────────────────
# Vercel Blob read/write token
# Vercel Dashboard → Project → Storage → Blob → Connect → copy BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=vercelblob_rw_...

# ─── Vercel KV (rate limiting) ────────────────────────────────────────────────
# Vercel Dashboard → Project → Storage → KV Database → Connect
# Vercel auto-injects these when KV is connected — no manual copy needed.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nicmiller.photography

# ─── Optional: Email Notifications ───────────────────────────────────────────
# Resend.com API key for contact form notifications. Leave blank to skip.
RESEND_API_KEY=
NOTIFICATION_EMAIL=nmiller3300@gmail.com
