# ─── Admin Auth ───────────────────────────────────────────────────────────────
ADMIN_PIN=004089
SESSION_SECRET=replace_with_32_plus_char_random_string

# ─── Database (Neon via Vercel) ───────────────────────────────────────────────
# Auto-injected when you connect Neon in Vercel Storage
NEON_DATABASE_URL=
NEON_POSTGRES_PRISMA_URL=

# ─── Image Storage (Cloudflare R2) ───────────────────────────────────────────
# 1. cloudflare.com → R2 → Create bucket (name: nm-photography)
# 2. R2 → Manage R2 API tokens → Create token (Object Read & Write)
# 3. Enable public access: bucket → Settings → Public access → Allow access → copy r2.dev URL
# 4. Account ID is in the Cloudflare dashboard right sidebar

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=nm-photography
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nicmillerphotography.vercel.app

# ─── Optional: Email Notifications ───────────────────────────────────────────
RESEND_API_KEY=
NOTIFICATION_EMAIL=nmiller3300@gmail.com
